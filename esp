local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

-- Função para calcular distância entre dois pontos
local function getDistance(pos1, pos2)
    return (pos1 - pos2).Magnitude
end

-- Quando um novo jogador entra
Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(character)
        local head = character:WaitForChild("Head")

        -- Cria uma tag acima da cabeça
        local tag = Instance.new("BillboardGui")
        tag.Size = UDim2.new(0, 200, 0, 50)
        tag.Adornee = head
        tag.Parent = character

        local text = Instance.new("TextLabel")
        text.Size = UDim2.new(1, 0, 1, 0)
        text.TextColor3 = Color3.new(1, 1, 1)
        text.BackgroundTransparency = 1
        text.Parent = tag

        -- Atualiza o texto com nome + distância
        game:GetService("RunService").RenderStepped:Connect(function()
            if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local myPos = localPlayer.Character.HumanoidRootPart.Position
                local otherPos = character:FindFirstChild("HumanoidRootPart").Position
                local dist = math.floor(getDistance(myPos, otherPos))
                text.Text = player.Name .. " (" .. dist .. " studs)"
            end
        end)
    end)
end)
